# generated by ansible
{% macro render_config(data, indent=0) -%}
{%- set shift = "  " * indent -%}
{%- for k, v in data.items() -%}
{#- Case 1: dict (recursive) -#}
{%- if v is mapping -%}
{{- shift }}{{- k }} {
{{ render_config(v, indent + 1) -}}
{{ shift }}}
{# Case 2: list -#}
{% elif v is sequence and v is not string -%}
{{ shift }}{{ k }} {
{% for item in v -%}
{{ shift }}  {{ item }}
{% endfor -%}
{{ shift }}}
{# Case 3: novalue -#}
{% elif v == 'novalue' -%}
{{ shift }}{{ k }}
{# Case 4: key, value -#}
{% else -%}
{{ shift }}{{ k }} {{ v }}
{% endif -%}
{% endfor -%}
{% endmacro -%}
{# Call macros with keepalived var #}
{{ render_config(keepalived) -}}
